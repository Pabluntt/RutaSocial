# FrontendWeb Dockerfile for Railway
FROM node:23.8-alpine AS build
WORKDIR /app
COPY FrontendWeb . 
RUN npm ci
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
